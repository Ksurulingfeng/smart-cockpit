# ============================================================
# 换行符规范
# 源码统一 LF 入库，检出时各平台自动转换
# ============================================================

# 自动检测文本文件
* text=auto

# --- C/C++ 源码 -> LF ---
*.c   text eol=lf
*.cpp text eol=lf
*.h   text eol=lf
*.hpp text eol=lf
*.s   text eol=lf
*.S   text eol=lf

# --- 构建系统 -> LF ---
CMakeLists.txt text eol=lf
*.cmake        text eol=lf
*.json         text eol=lf
*.txt          text eol=lf
*.md           text eol=lf
*.yaml         text eol=lf
*.yml          text eol=lf
*.ini          text eol=lf
*.cfg          text eol=lf
*.xml          text eol=lf

# --- Qt -> LF ---
*.ui  text eol=lf
*.qrc text eol=lf
*.pro text eol=lf

# --- 脚本 -> LF ---
*.sh text eol=lf
*.py text eol=lf

# --- 链接脚本 -> LF ---
*.ld  text eol=lf
*.sct text eol=lf
*.icf text eol=lf

# --- Keil MDK 工程文件 -> CRLF (Keil IDE 需要) ---
*.uvprojx text eol=crlf
*.uvoptx  text eol=crlf

# --- 二进制文件不做转换 ---
*.png   binary
*.jpg   binary
*.jpeg  binary
*.zip   binary
*.pdf   binary
*.xlsx  binary
*.xls   binary
*.bin   binary
*.hex   binary
*.axf   binary
*.o     binary
*.obj   binary
*.a     binary
*.so    binary
*.lib   binary
*.dll   binary
*.exe   binary
*.ttf   binary
*.otf   binary
*.woff  binary
*.woff2 binary
*.mp3   binary
*.wav   binary
*.ico   binary
